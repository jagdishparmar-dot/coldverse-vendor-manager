# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cldv_vendors?schema=public"
# Max connections per app instance (Coolify / small Postgres: keep low, e.g. 3–5)
PG_POOL_MAX="5"

# Storage driver: "s3" (default) or "local" (writes to next-app/uploads)
STORAGE_DRIVER="s3"
# LOCAL_UPLOADS_DIR="./uploads"

# S3-compatible object storage for invoice files (AWS S3, RustFS, MinIO, R2, etc.)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="coldverse-invoices"
# Alias also supported: S3_BUCKET_NAME

# RustFS / MinIO / self-hosted S3: path-style is auto-enabled for non-AWS endpoints.
# Override only if needed:
# S3_FORCE_PATH_STYLE="true"

# Self-signed or private CA certificates (common with RustFS behind HTTPS):
# S3_TLS_REJECT_UNAUTHORIZED="false"

S3_PUBLIC_BASE_URL=""

# Admin authentication (better-auth)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
SEED_ADMIN_EMAIL="admin@shreemaruti.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Shree Maruti Admin"

# Resend transactional email (optional locally — skipped if RESEND_API_KEY is empty)
# Also used for vendor portal OTP backup when SMS fails or is undelivered (vendor must have email on file)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Shree Maruti Billing <billing@yourdomain.com>"

# Docker / Coolify startup (optional)
RUN_DB_MIGRATIONS="true"
SEED_ADMIN_ON_STARTUP="false"
PORT=3000
HOSTNAME="0.0.0.0"

# Sentry (https://sentry.io — org: smile-jg / project: vendor-manager-smile)
# Client + server DSN from Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""
# Optional server-only alias (falls back to NEXT_PUBLIC_SENTRY_DSN)
# SENTRY_DSN=""
# Auth token for source map uploads during `next build` (Settings → Auth Tokens)
# SENTRY_AUTH_TOKEN=""
SENTRY_ORG="smile-jg"
SENTRY_PROJECT="vendor-manager-smile"
# EU org region (required for CLI / source maps): https://de.sentry.io
SENTRY_URL="https://de.sentry.io"

# --- Vendor portal OTP SMS (SmartPing) ---
# Optional shared DLT message (SmartPing uses full text with {otp})
# SMS_OTP_TEXT_TEMPLATE="Dear Vendor, the confirmation Code for logging into the vendor portal is {otp} Valid for 10 mins. Team SMILe"
# Smoke test: npx tsx scripts/sms-smoke-test.ts 98XXXXXXXX
# SMS_TEST_TO=""

# SmartPing / Omni (POST {base}/fe/api/v1/send)
SMARTPING_SMS_BASE_URL=""
SMARTPING_SMS_USERNAME=""
SMARTPING_SMS_PASSWORD=""
SMARTPING_SMS_FROM=""
SMARTPING_SMS_TEMPLATE_ID=""
SMARTPING_SMS_DLT_CONTENT_ID=""
# DLT Principal Entity (PE) ID — required on some routes; map in SmartPing panel too
# SMARTPING_SMS_PE_ID=""
SMARTPING_SMS_TEXT_TEMPLATE=""
SMARTPING_SMS_UNICODE="false"
# Legacy aliases (still supported): OMNI_SMS_BASE_URL, OMNI_SMS_USERNAME, etc.
