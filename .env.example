# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cldv_vendors?schema=public"

# S3-compatible object storage for invoice files (AWS S3, RustFS, MinIO, R2, etc.)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="coldverse-invoices"
# Alias also supported: S3_BUCKET_NAME

# RustFS / MinIO / self-hosted S3: path-style is auto-enabled for non-AWS endpoints.
# Override only if needed:
# S3_FORCE_PATH_STYLE="true"

# Self-signed or private CA certificates (common with RustFS behind HTTPS):
# S3_TLS_REJECT_UNAUTHORIZED="false"

S3_PUBLIC_BASE_URL=""

# Admin authentication (better-auth)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
SEED_ADMIN_EMAIL="admin@coldverse.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Coldverse Admin"

# Docker / Coolify startup (optional)
RUN_DB_MIGRATIONS="true"
SEED_ADMIN_ON_STARTUP="false"
PORT=3000
HOSTNAME="0.0.0.0"
